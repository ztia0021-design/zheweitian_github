{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Population by Climate Zone in Australia",
    "subtitle": "Same climate grouped together | Bar = total population",
    "fontSize": 16,
    "subtitleFontSize": 11
  },
  "width": 600,
  "height": 400,
  "data": {
    "values": [
      {"climate": "Cool Temperate", "states": "Victoria, Tasmania, ACT", "total_population": 7851300},
      {"climate": "Temperate / Subtropical", "states": "New South Wales", "total_population": 8339300},
      {"climate": "Tropical / Subtropical", "states": "Queensland", "total_population": 5459400},
      {"climate": "Mediterranean", "states": "South Australia", "total_population": 1851700},
      {"climate": "Mediterranean / Arid", "states": "Western Australia", "total_population": 2878600},
      {"climate": "Tropical Monsoon / Arid", "states": "Northern Territory", "total_population": 252500}
    ]
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "climate",
      "type": "nominal",
      "title": "Climate Type",
      "sort": "-y"
    },
    "y": {
      "field": "total_population",
      "type": "quantitative",
      "title": "Total Population",
      "axis": {"format": "s"}
    },
    "color": {
      "field": "climate",
      "type": "nominal",
      "title": "Climate Type",
      "scale": {
        "domain": ["Cool Temperate", "Temperate / Subtropical", "Tropical / Subtropical", "Mediterranean", "Mediterranean / Arid", "Tropical Monsoon / Arid"],
        "range": ["#3288bd", "#66c2a5", "#fdae61", "#f46d43", "#d53e4f", "#a6d96a"]
      }
    },
    "tooltip": [
      {"field": "climate", "title": "Climate Type"},
      {"field": "states", "title": "States/Territories"},
      {"field": "total_population", "title": "Total Population", "format": ",.0f"}
    ]
  }
}