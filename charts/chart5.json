{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "background": null,
  "title": {
    "text": "Population of Australian States and Territories",
    "subtitle": "Colored by Climate Type | Area = Population Size",
    "fontSize": 16,
    "subtitleFontSize": 11
  },
  "width": 400,
  "height": 300,
  "padding": 0,

  "data": [
    {
      "name": "table",
      "values": [
        {"state": "Australia", "parent": null},

        {"state": "New South Wales", "parent": "Australia", "population": 8339300, "climate": "Temperate / Subtropical"},
        {"state": "Victoria", "parent": "Australia", "population": 6812500, "climate": "Cool Temperate"},
        {"state": "Queensland", "parent": "Australia", "population": 5459400, "climate": "Tropical / Subtropical"},
        {"state": "Western Australia", "parent": "Australia", "population": 2878600, "climate": "Mediterranean / Arid"},
        {"state": "South Australia", "parent": "Australia", "population": 1851700, "climate": "Mediterranean"},
        {"state": "Tasmania", "parent": "Australia", "population": 572800, "climate": "Cool Temperate"},
        {"state": "Australian Capital Territory", "parent": "Australia", "population": 466000, "climate": "Cool Temperate"},
        {"state": "Northern Territory", "parent": "Australia", "population": 252500, "climate": "Tropical Monsoon / Arid"}
      ],
      "transform": [
        {
          "type": "stratify",
          "key": "state",
          "parentKey": "parent"
        },
        {
          "type": "treemap",
          "field": "population",
          "sort": {"field": "population", "order": "descending"},
          "round": true,
          "method": "squarify",
          "size": [{"signal": "width"}, {"signal": "height"}],
          "padding": 2
        }
      ]
    }
  ],

  "scales": [
    {
      "name": "color",
      "type": "ordinal",
      "domain": [
        "Temperate / Subtropical",
        "Cool Temperate",
        "Tropical / Subtropical",
        "Mediterranean / Arid",
        "Mediterranean",
        "Tropical Monsoon / Arid"
      ],
      "range": [
        "#66c2a5",
        "#3288bd",
        "#fdae61",
        "#d53e4f",
        "#f46d43",
        "#a6d96a"
      ]
    }
  ],

  "legends": [
    {
      "fill": "color",
      "title": "Climate Type",
      "orient": "left",
      "offset": 20
    }
  ],

  "marks": [
    {
      "type": "rect",
      "from": {"data": "table"},
      "encode": {
        "enter": {
          "stroke": {"value": "white"},
          "strokeWidth": {"value": 1.5},
          "tooltip": {
            "signal": "{'State/Territory': datum.state, 'Population': format(datum.population, ','), 'Climate': datum.climate}"
          }
        },
        "update": {
          "x": {"field": "x0"},
          "y": {"field": "y0"},
          "x2": {"field": "x1"},
          "y2": {"field": "y1"},
          "fill": {"scale": "color", "field": "climate"}
        }
      }
    },
    {
      "type": "text",
      "from": {"data": "table"},
      "encode": {
        "enter": {
          "fontSize": {"value": 12},
          "fill": {"value": "white"},
          "fontWeight": {"value": "bold"},
          "align": {"value": "center"},
          "baseline": {"value": "middle"}
        },
        "update": {
          "x": {"signal": "(datum.x0 + datum.x1) / 2"},
          "y": {"signal": "(datum.y0 + datum.y1) / 2"},
          "text": {"field": "state"}
        }
      }
    }
  ]
}